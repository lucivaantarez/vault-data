<script>
// ═══════════════════════════════════════
// 9. HARDWARE HAPTIC FEEDBACK
// ═══════════════════════════════════════
const haptic = (type = 'light') => {
  if (!navigator.vibrate) return;
  if (type === 'light') navigator.vibrate(15);
  else if (type === 'heavy') navigator.vibrate([30, 50, 30]);
};

// ═══════════════════════════════════════
// STATE & CONSTANTS
// ═══════════════════════════════════════
const SK='cookie_vault_v1', CK='cv_cols', SORT_K='cv_sort', SET_K='cv_settings';
const COOKIE_PFX='_|WARNING:-DO-NOT-SHARE-THIS.';
const REAL_PIN='180801';
const PALETTE=[
  {c:'#00d4ff',r:'0,212,255'},{c:'#7b2fff',r:'123,47,255'},
  {c:'#00ffaa',r:'0,255,170'},{c:'#ff6b00',r:'255,107,0'},
  {c:'#ff3060',r:'255,48,96'},{c:'#ffaa00',r:'255,170,0'},
  {c:'#00aaff',r:'0,170,255'},{c:'#ff00aa',r:'255,0,170'},
  {c:'#aaff00',r:'170,255,0'},{c:'#aa00ff',r:'170,0,255'},
];
const ccache={};

let vault=loadVault();
let trash=JSON.parse(localStorage.getItem('cv_trash')||'[]');
let pending=[], panelId=null, bulkGroups=[], bulkLabel='';
let cols=parseInt(localStorage.getItem(CK))||2;
let sort=localStorage.getItem(SORT_K)||'az';
let settings=loadSettings();
let activeSrv='all';
let selectedCards=new Set();
let ctxGroupId=null;

// Security & Network State
let pinBuffer='', pinFails=parseInt(localStorage.getItem('cv_pin_fails')||'0'), pinLocked=false, pinLockUntil=parseInt(localStorage.getItem('cv_pin_lock_until')||'0'), decoyMode=false;
let banCheckRunning=false, banCheckAbort=false, banWorkerIdx=0, banFailedCookies=[];

// ═══════════════════════════════════════
// CORE STORAGE
// ═══════════════════════════════════════
function getColor(name){
  if(!name)return PALETTE[0];
  const k=(name||'').trim().toLowerCase();
  if(ccache[k])return ccache[k];
  let h=0;for(const c of k)h=(h*31+c.charCodeAt(0))>>>0;
  return ccache[k]=PALETTE[h%PALETTE.length];
}
function loadSettings(){ try{const r=localStorage.getItem(SET_K);return r?{...defSettings(),...JSON.parse(r)}:defSettings();}catch{return defSettings();} }
function defSettings(){return{vaultName:'Cookie Vault',firstCreated:Date.now(),lastOpen:null,lastBackup:null,cardSize:'md',streak:0};}
function saveSettings(){localStorage.setItem(SET_K,JSON.stringify(settings));}
function saveVault(){
  if(decoyMode) return; // RULE-06, RULE-18: Decoy Guard
  try{
    localStorage.setItem(SK,JSON.stringify(vault));
    localStorage.setItem('cv_trash',JSON.stringify(trash));
    document.getElementById('trash-cnt').textContent=trash.length;
  }catch(e){
    if(e.name==='QuotaExceededError') toast('Storage full — export a backup now.','err');
  }
}
function loadVault(){ try{const r=localStorage.getItem(SK);return r?JSON.parse(r):[]}catch{return[];} }
function esc(s){if(!s)return'';return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function toast(msg,type='ok'){
  const t=document.getElementById('toast');
  document.getElementById('toast-msg').textContent=msg;
  t.className=`show ${type}`;
  setTimeout(()=>t.className='',3000);
}

// ═══════════════════════════════════════
// 13. APP-SWITCHER PRIVACY BLUR
// ═══════════════════════════════════════
document.addEventListener('visibilitychange', () => {
  if (document.hidden) document.body.classList.add('privacy-blur');
  else document.body.classList.remove('privacy-blur');
});

// ═══════════════════════════════════════
// 6. TOUCH PIN PAD LOGIC
// ═══════════════════════════════════════
function initPin(){
  const scr=document.getElementById('pin-screen');
  if(pinLockUntil > Date.now()){ pinLocked=true; showPinLockCountdown(); }
  
  const dots=document.querySelectorAll('.pin-dot');
  document.getElementById('pin-pad').addEventListener('touchstart', e => {
    const k=e.target.closest('.pin-key'); if(!k) return;
    e.preventDefault(); haptic('light');
    if(pinLocked) return;
    
    const v=k.dataset.v;
    if(v==='clear') pinBuffer='';
    else if(v==='del') pinBuffer=pinBuffer.slice(0,-1);
    else if(pinBuffer.length < 6) pinBuffer+=v;
    
    dots.forEach((d,i) => d.classList.toggle('filled', i < pinBuffer.length));
    if(pinBuffer.length === 6) submitPin();
  });
}
function showPinLockCountdown(){
  const msg=document.getElementById('pin-lock-msg');
  const err=document.getElementById('pin-err');
  err.textContent='';
  function tick(){
    const rem=Math.ceil((pinLockUntil-Date.now())/1000);
    if(rem<=0){pinLocked=false; localStorage.removeItem('cv_pin_lock_until'); msg.textContent=''; return;}
    msg.textContent=`locked — try again in ${rem}s`;
    setTimeout(tick,500);
  }
  tick();
}
function submitPin(){
  const scr=document.getElementById('pin-screen');
  const err=document.getElementById('pin-err');
  const decoy=localStorage.getItem('cv_decoy_pin')||'';
  
  if(pinBuffer===REAL_PIN){
    decoyMode=false; pinFails=0; localStorage.removeItem('cv_pin_fails'); localStorage.removeItem('cv_pin_lock_until');
    haptic('heavy');
    scr.classList.add('hidden'); setTimeout(()=>scr.style.display='none',300);
    render();
  } else if(decoy && pinBuffer===decoy){
    decoyMode=true; vault=[]; pinFails=0; localStorage.removeItem('cv_pin_fails');
    haptic('heavy');
    scr.classList.add('hidden'); setTimeout(()=>{scr.style.display='none'; render();},300);
  } else {
    navigator.vibrate([50,100,50]);
    pinFails++; localStorage.setItem('cv_pin_fails',pinFails);
    const lockout = pinFails>=5 ? 120 : pinFails>=3 ? 30 : 0;
    if(lockout>0){
      pinLocked=true; pinLockUntil=Date.now()+(lockout*1000);
      localStorage.setItem('cv_pin_lock_until',pinLockUntil);
      showPinLockCountdown();
    }
    err.textContent=`wrong PIN${pinFails>=3?' — '+pinFails+' attempts':''}`;
  }
  pinBuffer=''; document.querySelectorAll('.pin-dot').forEach(d=>d.classList.remove('filled'));
}
initPin();

// ═══════════════════════════════════════
// 10. SYSTEM-SAFE DRAWER
// ═══════════════════════════════════════
const sidebar=document.getElementById('sidebar');
const drawerOverlay=document.getElementById('drawer-overlay');
document.getElementById('menu-pill').addEventListener('click', () => {
  haptic(); sidebar.classList.add('open'); drawerOverlay.classList.add('active');
});
drawerOverlay.addEventListener('click', () => {
  sidebar.classList.remove('open'); drawerOverlay.classList.remove('active');
});

// ═══════════════════════════════════════
// 5. PINCH-TO-ZOOM DYNAMIC GRID
// ═══════════════════════════════════════
let initialDistance = 0;
document.documentElement.style.setProperty('--cols', cols);
document.getElementById('main').addEventListener('touchstart', e => {
  if (e.touches.length === 2) {
    initialDistance = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
  }
});
document.getElementById('main').addEventListener('touchmove', e => {
  if (e.touches.length === 2) {
    const currentDistance = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
    if (currentDistance > initialDistance + 60) {
      cols = Math.max(1, cols - 1); localStorage.setItem(CK, cols);
      document.documentElement.style.setProperty('--cols', cols);
      initialDistance = currentDistance; haptic();
    } else if (currentDistance < initialDistance - 60) {
      cols = Math.min(4, cols + 1); localStorage.setItem(CK, cols);
      document.documentElement.style.setProperty('--cols', cols);
      initialDistance = currentDistance; haptic();
    }
  }
});

// ═══════════════════════════════════════
// 4. WEB WORKER FOR HEAVY IMPORTS
// ═══════════════════════════════════════
const workerCode = `
self.onmessage = function(e) {
  const COOKIE_PFX = '_|WARNING:-DO-NOT-SHARE-THIS.';
  const lines = e.data.split('\\n');
  const parsed = [];
  for(let i=0; i<lines.length; i++){
    let line = lines[i].trim(); if(!line) continue;
    let idx = line.indexOf(COOKIE_PFX); if(idx===-1) continue;
    let cookie = line.substring(idx), pre = line.substring(0,idx).replace(/:$/,'');
    if(!pre) parsed.push({username:null,password:null,cookie});
    else {
      let ci = pre.indexOf(':');
      if(ci===-1) parsed.push({username:pre,password:null,cookie});
      else parsed.push({username:pre.substring(0,ci),password:pre.substring(ci+1),cookie});
    }
  }
  self.postMessage(parsed);
};
`;
const blob = new Blob([workerCode], {type: 'application/javascript'});
const worker = new Worker(URL.createObjectURL(blob));

worker.onmessage = function(e) {
  const parsed = e.data;
  if(!parsed.length) { toast('No valid cookies found', 'err'); document.getElementById('add-btn').disabled=false; return; }
  
  const existingCookies = new Set(vault.flatMap(g => g.cookies.map(c => c.cookie)));
  const clean = parsed.filter(c => !existingCookies.has(c.cookie));
  
  if(!clean.length) { toast('All duplicates skipped', 'warn'); document.getElementById('add-btn').disabled=false; return; }
  
  const group = {
    id: Date.now().toString(36) + Math.random().toString(36).slice(2,5),
    name: `Imported ${new Date().toLocaleTimeString()}`,
    createdAt: Date.now(), pinned: false, banned: false, alternatives: [],
    cookies: clean
  };
  
  vault.unshift(group); saveVault(); render();
  document.getElementById('paste-ta').value = '';
  document.getElementById('paste-info').textContent = 'Awaiting input...';
  document.getElementById('add-btn').disabled = false;
  haptic('heavy');
  toast(`Imported ${clean.length} cookies (${parsed.length - clean.length} dupes skipped)`, 'ok');
};

document.getElementById('paste-ta').addEventListener('input', () => {
  const val = document.getElementById('paste-ta').value.trim();
  const info = document.getElementById('paste-info');
  const btn = document.getElementById('add-btn');
  if(!val) { info.textContent = 'Awaiting input...'; btn.disabled=true; return; }
  info.textContent = 'Data pasted. Ready to process.';
  btn.disabled=false;
});

document.getElementById('add-btn').addEventListener('click', () => {
  const txt = document.getElementById('paste-ta').value;
  if(!txt.trim()) return;
  document.getElementById('add-btn').disabled = true;
  document.getElementById('paste-info').textContent = 'Processing via Web Worker...';
  worker.postMessage(txt);
});

// ═══════════════════════════════════════
// 7. FAB ONE-TAP PASTE
// ═══════════════════════════════════════
document.getElementById('fab-paste').addEventListener('click', async () => {
  haptic();
  try {
    const text = await navigator.clipboard.readText();
    if (text && text.includes(COOKIE_PFX)) {
      toast('Processing clipboard data...', 'ok');
      worker.postMessage(text);
    } else {
      toast('No valid cookies in clipboard', 'err');
    }
  } catch(e) { toast('Clipboard permission denied', 'err'); }
});
// ═══════════════════════════════════════
// 15. NATIVE HORIZONTAL SWIPE TABS
// ═══════════════════════════════════════
function buildSwipeTabs() {
  const tabs = document.getElementById('swipe-tabs');
  const servers = new Set();
  vault.forEach(g => { if(g.serverName) servers.add(g.serverName.trim().toLowerCase()); });
  
  let html = `<div class="swipe-tab ${activeSrv==='all'?'active':''}" data-t="all">All Data</div>`;
  servers.forEach(s => {
    html += `<div class="swipe-tab ${activeSrv===s?'active':''}" data-t="${esc(s)}">${esc(s)}</div>`;
  });
  tabs.innerHTML = html;
  
  tabs.querySelectorAll('.swipe-tab').forEach(t => {
    t.addEventListener('click', () => {
      haptic('light');
      activeSrv = t.dataset.t;
      buildSwipeTabs();
      applyFilter();
    });
  });
}

// ═══════════════════════════════════════
// FILTERING (Search & Tabs)
// ═══════════════════════════════════════
document.getElementById('search-in').addEventListener('input', applyFilter);
const sbNav = document.getElementById('sb-nav');

sbNav.addEventListener('click', e => {
  const item = e.target.closest('[data-filter]');
  if(!item) return;
  haptic();
  sbNav.querySelectorAll('.sb-all, .sb-item').forEach(x => x.classList.remove('on'));
  item.classList.add('on');
  document.activeFilter = item.dataset.filter; 
  applyFilter();
  sidebar.classList.remove('open'); 
  drawerOverlay.classList.remove('active');
});

function applyFilter() {
  const q = document.getElementById('search-in').value.trim().toLowerCase();
  const filter = document.activeFilter || 'all';
  
  document.querySelectorAll('.gcard').forEach(card => {
    let hide = false;
    if(activeSrv !== 'all' && card.dataset.srv !== activeSrv) hide = true;
    
    if(!hide) {
      if(filter === 'pinned' && card.dataset.pinned !== '1') hide = true;
      if(filter === 'banned' && card.dataset.banned !== '1') hide = true;
      if(filter === 'alts' && card.dataset.alts !== '1') hide = true;
    }
    
    if(!hide && q) {
      hide = !card.dataset.name.includes(q) && !card.dataset.srv.includes(q) && !(card.dataset.users||'').includes(q);
    }
    card.classList.toggle('dim', hide);
  });
}

// ═══════════════════════════════════════
// DYNAMIC GRID RENDERING
// ═══════════════════════════════════════
function sortVault(arr){
  return [...arr.filter(g=>g.pinned), ...arr.filter(g=>!g.pinned)]; 
}

function render(){
  const vEl=document.getElementById('vault');
  vEl.innerHTML='';
  buildSwipeTabs();
  
  if(!vault.length){
    vEl.innerHTML=`<div style="text-align:center; padding:70px 20px; color:var(--dim); font-family:var(--mono);">No cookies stored yet.<br>Paste or import to begin.</div>`;
    return;
  }
  
  const grid = document.createElement('div');
  grid.className = 'card-grid';
  grid.style.setProperty('--cols', cols);
  
  const sorted = sortVault(vault);
  sorted.forEach(g => {
    grid.appendChild(mkCard(g));
  });
  vEl.appendChild(grid);
  updateBulkActionBar();
  applyFilter();
}

// ═══════════════════════════════════════
// 3. MULTI-SELECT & 14. CONTEXT MENU
// ═══════════════════════════════════════
const ctxMenu = document.getElementById('context-menu');
document.addEventListener('touchstart', e => {
  if(!e.target.closest('.gcard') && !e.target.closest('#context-menu')) {
    ctxMenu.style.display = 'none';
  }
});

function mkCard(group){
  const card=document.createElement('div');
  card.className=`gcard ${selectedCards.has(group.id)?'selected':''} ${group.banned?'banned':''}`;
  card.dataset.id=group.id;
  card.dataset.name=group.name.toLowerCase();
  card.dataset.srv=(group.serverName||'').trim().toLowerCase();
  card.dataset.users=group.cookies.map(c=>c.username||'').join(' ').toLowerCase();
  card.dataset.pinned=group.pinned?'1':'0';
  card.dataset.banned=group.banned?'1':'0';
  card.dataset.alts=(group.alternatives&&group.alternatives.length)?'1':'0';
  
  const col=getColor(group.serverName);
  
  let statusLine = '';
  const active = group.cookies.filter(c=>c.banStatus==='active').length;
  const banned = group.cookies.filter(c=>c.banStatus==='banned').length;
  if(active) statusLine += `<span style="color:var(--ok)">${active} Active</span> `;
  if(banned) statusLine += `<span style="color:var(--danger)">${banned} Banned</span>`;

  card.innerHTML=`
    <div class="gcard-bar" style="background:${col.c}"></div>
    <div class="gcard-body">
      <div class="gcard-name">${esc(group.name)}</div>
      <div class="gcard-count">${group.cookies.length} Cookies</div>
      ${statusLine ? `<div style="font-family:var(--mono); font-size:11px; margin-top:5px;">${statusLine}</div>` : ''}
      ${group.serverName ? `<div class="gcard-srv">${esc(group.serverName)}</div>` : ''}
    </div>
  `;
  
  if(group.pinned){
    const pin = document.createElement('div');
    pin.style.cssText = "position:absolute; top:12px; right:14px; font-size:14px;";
    pin.textContent = '📌';
    card.appendChild(pin);
  }

  // Tablet Long Press Mechanics
  let touchTimer;
  card.addEventListener('touchstart', e => {
    touchTimer = setTimeout(() => {
      haptic('heavy');
      ctxGroupId = group.id;
      const touch = e.touches[0];
      ctxMenu.style.display = 'block';
      ctxMenu.style.left = `${Math.min(touch.clientX, window.innerWidth - 200)}px`;
      ctxMenu.style.top = `${touch.clientY}px`;
    }, 600); // 600ms hold
  });
  
  card.addEventListener('touchmove', () => clearTimeout(touchTimer));
  card.addEventListener('touchend', e => {
    clearTimeout(touchTimer);
    if(e.changedTouches.length > 0 && touchTimer) { // Was a quick tap
       if(selectedCards.size > 0) {
         toggleSelection(group.id); 
       } else {
         openPanel(group.id); 
       }
    }
  });
  
  return card;
}

function toggleSelection(id) {
  if(selectedCards.has(id)) selectedCards.delete(id);
  else selectedCards.add(id);
  haptic('light');
  render();
}

