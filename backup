// GITHUB GIST SYNC LOGIC
// ═══════════════════════════════════════
const GH_PAT_K='cv_gh_pat', GH_GIST_K='cv_gh_gist', GH_EN_K='cv_gh_enabled';
function ghEnabled(){ return localStorage.getItem(GH_EN_K)==='1' && !!localStorage.getItem(GH_PAT_K) && !!localStorage.getItem(GH_GIST_K); }

function scheduleGhSync(){
  if(!ghEnabled()) return;
  const dot = document.getElementById('sync-dot'); if(dot) dot.style.background = 'var(--warn)';
  clearTimeout(ghDebounceTimer);
  ghDebounceTimer = setTimeout(doGhSync, 3000); // 3 second debounce
}

async function doGhSync(){
  if(!ghEnabled() || !navigator.onLine) return;
  const dot = document.getElementById('sync-dot'); if(dot) dot.style.background = 'var(--ac)';
  try {
    const pat = localStorage.getItem(GH_PAT_K), gist = localStorage.getItem(GH_GIST_K);
    const body = JSON.stringify({files:{'cookie-vault.json':{content:JSON.stringify({version:1,exported:Date.now(),vault},null,2)}}});
    const r = await fetch('https://api.github.com/gists/'+gist, {method:'PATCH', headers:{'Authorization':'token '+pat,'Content-Type':'application/json'}, body});
    if(!r.ok) throw new Error('HTTP '+r.status);
    if(dot) dot.style.background = 'var(--ok)';
  } catch(e) {
    if(dot) dot.style.background = 'var(--danger)';
    toast('GitHub sync failed', 'err');
  }
}

