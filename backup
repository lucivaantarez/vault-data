       if(c.username && c.password) txt = `${c.username}:${c.password}:${c.cookie}`;
       else if(c.username) txt = `${c.username}:${c.cookie}`;
       if(navigator.clipboard) { navigator.clipboard.writeText(txt).then(()=>toast('Copied!')); }
