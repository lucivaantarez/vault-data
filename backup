<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#000000">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<link rel="manifest" href="manifest.json">
<title>Cookie Vault v4.9</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  /* Pure Black Stealth Theme */
  --bg:#000000;--surf:#0a0a0a;--surf2:#111111;
  --solid:#000000;--bdr:#222222;--bdrb:rgba(15,111,255,.4);
  --ac:#0f6fff;--a2:#00d4ff;--a3:#7b2fff;
  --txt:#c8daf0;--dim:#4a6a8a;--bright:#ffffff;
  --danger:#ff3060;--ok:#00ffaa;--warn:#ffaa00;
  --mono:'Share Tech Mono',monospace;--sans:'Rajdhani',sans-serif;
  --sw:280px;--hh:64px;
  --cols: 2; /* dynamically updated by pinch-to-zoom */
}
*{margin:0;padding:0;box-sizing:border-box; user-select:none; -webkit-tap-highlight-color: transparent;}
html,body{height:100%;overflow:hidden;}
body{background:var(--bg);color:var(--txt);font-family:var(--sans);display:flex;flex-direction:column; transition: filter 0.2s ease;}

/* App-Switcher Privacy Blur */
body.privacy-blur { filter: blur(20px) brightness(0.5); pointer-events: none; }

body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:
    radial-gradient(ellipse 60% 50% at 15% 10%,rgba(15,111,255,.07) 0%,transparent 70%),
    radial-gradient(ellipse 50% 40% at 85% 85%,rgba(123,47,255,.06) 0%,transparent 70%);}

/* ── APP SHELL ── */
#app{display:flex;flex-direction:column;height:100%;position:relative;z-index:1;overflow:hidden;}

/* ── HEADER ── */
.hdr{height:var(--hh);display:flex;align-items:center;padding:0 18px;gap:12px;
  border-bottom:1px solid var(--bdr);background:var(--bg);
  flex-shrink:0;position:relative;z-index:10;}
.hdr-icon{width:36px;height:36px;background:linear-gradient(135deg,var(--ac),var(--a3));
  border-radius:10px;display:flex;align-items:center;justify-content:center;
  box-shadow:0 0 14px rgba(15,111,255,.35);flex-shrink:0;}
.hdr-title{font-family:var(--sans);font-weight:700;font-size:18px;letter-spacing:2px;
  text-transform:uppercase;color:var(--bright);white-space:nowrap;}
.hdr-title span{color:var(--a2);}
.hdr-search{flex:1;max-width:300px;position:relative;}
.hdr-search input{width:100%;background:rgba(255,255,255,.06);border:1px solid var(--bdr);
  border-radius:10px;padding:12px 14px 12px 36px;font-family:var(--mono);font-size:14px;color:var(--txt);
  outline:none;transition:border-color .15s;}
.hdr-search input:focus{border-color:var(--ac);}
.hdr-search input::placeholder{color:var(--dim);}
.srch-ico{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--dim);pointer-events:none;}
.hdr-right{display:flex;align-items:center;gap:10px;margin-left:auto;flex-shrink:0;}

/* ── BODY LAYOUT (Responsive Split-Pane) ── */
.app-body{flex:1;display:flex;overflow:hidden;position:relative;}

/* ── OFF-CANVAS DRAWER & SIDEBAR ── */
.sidebar{width:var(--sw);flex-shrink:0;border-right:1px solid var(--bdr);
  background:var(--surf);display:flex;flex-direction:column;overflow:hidden;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); z-index: 900;}
#drawer-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.8); z-index:899;}
#drawer-overlay.active { display:block; }

/* The Floating Menu Pill */
#menu-pill { display: none; position: absolute; bottom: 30px; left: 20px; background: var(--surf2); border: 1px solid var(--bdr); color: var(--bright); padding: 14px 24px; border-radius: 30px; z-index: 100; font-family: var(--sans); font-weight: 700; font-size: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.8); }

@media (max-width: 900px) and (orientation: portrait) {
  .sidebar { position: fixed; left: 0; top: 0; bottom: 0; transform: translateX(-100%); }
  .sidebar.open { transform: translateX(0); }
  #menu-pill { display: block; }
}

.sb-hd{padding:16px;border-bottom:1px solid var(--bdr);flex-shrink:0;}
.sb-lbl{font-family:var(--mono);font-size:11px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;}
.sb-nav{flex:1;overflow-y:auto;padding:10px 0; scrollbar-width: none;}
.sb-all{font-family:var(--mono);font-size:14px;letter-spacing:1px;color:var(--dim);
  padding:12px 18px;display:flex;align-items:center;gap:12px;}
.sb-all.on{color:var(--a2);}
.sb-div{height:1px;background:var(--bdr);margin:10px 18px;}
.sb-item{display:flex;align-items:center;gap:12px;padding:12px 18px;position:relative;}
.sb-item.on{background:rgba(15,111,255,.1);}
.sb-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;box-shadow:0 0 8px currentColor;}
.sb-name{font-family:var(--sans);font-weight:600;font-size:16px;color:var(--txt);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;}
.sb-item.on .sb-name{color:var(--bright);}
.sb-badge{font-family:var(--mono);font-size:11px;color:var(--dim);flex-shrink:0;}

/* ── SIDEBAR COMMAND DOCK ── */
.sb-dock{padding:14px;border-top:1px solid var(--bdr);background:var(--bg);flex-shrink:0;}
.sb-dock-label{font-family:var(--sans);font-weight:700;font-size:12px;color:var(--dim);letter-spacing:2px;
  text-transform:uppercase;margin-bottom:12px;}
.sb-dock-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.dock-cmd{display:flex;align-items:center;gap:12px;padding:14px;
  background:rgba(255,255,255,.04);border:1px solid var(--bdr);border-radius:12px;
  min-height:64px; flex-direction: column; justify-content: center; text-align: center;}
.dock-cmd:active{background:rgba(255,255,255,.08);}
.dock-cmd svg{flex-shrink:0;opacity:0.8; width: 20px; height: 20px;}
.dock-cmd-txt{font-family:var(--sans);font-weight:600;font-size:14px;color:var(--bright);letter-spacing:.5px;}
.dock-cmd.full{grid-column:1/-1; flex-direction: row;}
.dock-cmd.danger .dock-cmd-txt{color:var(--danger);}

/* ── MAIN WORKSPACE ── */
.main{flex:1;overflow-y:auto;overflow-x:hidden;padding:20px; position:relative; scrollbar-width: none;}

/* ── NATIVE HORIZONTAL SWIPE TABS ── */
.swipe-tabs { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; gap: 15px; padding-bottom: 15px; margin-bottom: 20px; scrollbar-width: none; border-bottom: 1px solid var(--bdr); }
.swipe-tab { scroll-snap-align: center; background: var(--surf2); padding: 14px 28px; border-radius: 30px; border: 1px solid var(--bdr); color: var(--dim); font-family: var(--sans); font-size: 16px; font-weight: 700; white-space: nowrap; transition: all 0.2s;}
.swipe-tab.active { background: var(--ac); color: #fff; border-color: var(--ac); }

/* ── CARDS & PINCH TO ZOOM GRID ── */
.card-grid{display:grid;grid-template-columns:repeat(var(--cols),1fr);gap:16px; margin-bottom: 30px;}
.gcard{background:var(--surf);border:1px solid var(--bdr);border-radius:18px;
  overflow:hidden;aspect-ratio:1/1;display:flex;flex-direction:column; position:relative;
  transition: transform 0.1s, border-color 0.2s;}
.gcard.selected { border-color: var(--ac); background: rgba(15,111,255,0.1); box-shadow: inset 0 0 0 2px var(--ac); }
.gcard.dim{opacity:.15;pointer-events:none;}
.gcard-bar{height:4px;flex-shrink:0;}
.gcard-body{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;padding:16px;}
.gcard-dot{border-radius:50%; width:12px; height:12px; box-shadow:0 0 8px currentColor;}
.gcard-name{font-family:var(--sans);font-weight:700;font-size:20px;color:var(--bright);text-align:center; word-break: break-word;}
.gcard-count{font-family:var(--mono);font-size:13px;color:var(--a2);background:rgba(0,212,255,.1);padding:4px 12px;border-radius:20px;}
.gcard-srv{font-family:var(--mono);font-size:12px;color:var(--a3);background:rgba(123,47,255,.1);padding:3px 10px;border-radius:20px;}
.gcard.banned { border-color: var(--danger); }
.gcard.banned .gcard-bar { background: var(--danger) !important; }

/* ── LONG PRESS CONTEXT MENU ── */
#context-menu { position: fixed; background: var(--surf2); border: 1px solid var(--bdr); border-radius: 16px; padding: 12px; display: none; z-index: 2000; box-shadow: 0 10px 40px rgba(0,0,0,0.9); }
.context-btn { display: block; width: 100%; padding: 18px 30px; color: var(--bright); background: none; border: none; text-align: left; font-family: var(--sans); font-size: 18px; font-weight:600; border-bottom: 1px solid var(--bdr);}
.context-btn:last-child { border-bottom: none; }
.context-btn.danger { color: var(--danger); }

/* ── THUMB ZONE, FAB, & BULK ACTIONS ── */
#thumb-zone { position: fixed; bottom: 24px; right: 24px; left: 24px; display: flex; justify-content: flex-end; pointer-events: none; z-index: 500; }
#fab-paste { background: var(--ac); color: #fff; width: 72px; height: 72px; border-radius: 50%; border: none; font-size: 32px; pointer-events: auto; box-shadow: 0 8px 24px rgba(15, 111, 255, 0.4); display:flex; align-items:center; justify-content:center;}
#fab-paste:active { transform: scale(0.95); }
#bulk-action-bar { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%) translateY(150%); background: var(--surf2); padding: 16px 36px; border-radius: 40px; display: flex; gap: 24px; pointer-events: auto; transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); border: 1px solid var(--bdr); box-shadow: 0 10px 30px rgba(0,0,0,0.8);}
#bulk-action-bar.active { transform: translateX(-50%) translateY(0); }
.bulk-btn { background: none; border: none; color: var(--bright); font-size: 16px; font-weight: bold; font-family: var(--sans);}
.bulk-btn.danger { color: var(--danger); }

/* ── PASTE PANEL / INLINE DATA ENTRY ── */
.paste-panel{background:var(--surf);border:1px solid var(--bdr);border-radius:14px;margin-bottom:20px;}
.paste-hd{display:flex;align-items:center;gap:12px;padding:16px 20px;border-bottom:1px solid var(--bdr); background:rgba(255,255,255,.02);}
.paste-hd-title{font-family:var(--mono);font-size:14px;color:var(--a2);flex:1;}
.paste-body{display:none;}
.paste-panel.open .paste-body{display:block;}
.paste-ta{width:100%;background:transparent;border:none;outline:none;padding:20px;
  font-family:var(--mono);font-size:14px;color:var(--ok);min-height:160px;}
.paste-ft{display:flex;align-items:center;justify-content:space-between;padding:14px 20px; border-top:1px solid var(--bdr); background:rgba(0,0,0,.3);}
.btn-primary{background:var(--ac);border:none;border-radius:10px;padding:14px 24px;font-family:var(--sans);font-weight:700; font-size:16px; color:#fff;}

/* ── SLIDE OUT DETAIL PANEL ── */
.p-overlay{position:fixed;inset:0;z-index:950;pointer-events:none;}
.p-back{position:absolute;inset:0;background:rgba(0,0,0,0);transition:background .25s;}
.p-overlay.open .p-back{background:rgba(0,0,0,.8);pointer-events:all;}
.detail-panel{position:absolute;right:0;top:0;bottom:0;width:min(600px, 90vw);
  background:var(--surf);border-left:1px solid var(--bdr);transform:translateX(100%);
  transition:transform .3s cubic-bezier(0.4, 0, 0.2, 1);display:flex;flex-direction:column;pointer-events:all;}
.p-overlay.open .detail-panel{transform:translateX(0);}
.p-hdr{padding:24px;border-bottom:1px solid var(--bdr);background:var(--surf2);}
.p-title-row{display:flex;align-items:flex-start;gap:14px;margin-bottom:14px;}
.p-name{font-family:var(--sans);font-weight:700;font-size:28px;color:var(--bright);flex:1;line-height:1.2;}
.p-close{background:rgba(255,255,255,.05);border:1px solid var(--bdr);border-radius:10px;color:var(--dim);padding:10px 18px;font-family:var(--mono);font-size:14px;}
.p-scroll{flex:1;overflow-y:auto;padding:20px; scrollbar-width: none;}
.ck-item{background:var(--bg);border:1px solid var(--bdr);border-radius:12px;margin-bottom:14px;font-family:var(--mono); font-size:14px; padding: 16px;}
.ck-line{margin-bottom: 8px; word-break: break-all;}
.ck-line-key{color:var(--dim);margin-right:10px; font-size:11px; letter-spacing:1px;}
.ck-actions{display:flex;gap:12px;margin-top:14px; border-top: 1px solid var(--bdr); padding-top: 12px;}
.ck-copy-btn, .ck-del-btn{background:var(--surf2);border:1px solid var(--bdr);padding:8px 16px;border-radius:8px;color:var(--bright); font-size: 12px;}
.ck-del-btn{color:var(--danger);}

/* ── PIN LOCK SCREEN (Giant Touch Grid) ── */
#pin-screen{position:fixed;inset:0;z-index:1000;background:var(--bg);display:flex;align-items:center;justify-content:center;flex-direction:column;}
#pin-screen.hidden{opacity:0;pointer-events:none;transition:opacity .3s;}
.pin-vault-name{font-family:var(--sans);font-weight:700;font-size:32px;color:var(--bright);margin-bottom:30px; letter-spacing: 3px; text-transform: uppercase;}
.pin-dots{display:flex;gap:20px;margin-bottom:40px;}
.pin-dot{width:20px;height:20px;border-radius:50%;border:2px solid var(--bdr);}
.pin-dot.filled{background:var(--a2);border-color:var(--a2);box-shadow:0 0 20px var(--a2);}
.pin-pad{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;width:340px;}
.pin-key{background:var(--surf2);border:1px solid var(--bdr);border-radius:24px;font-family:var(--mono);font-size:36px;color:var(--bright);padding:24px 0;text-align:center;}
.pin-key:active{transform:scale(0.95); background:rgba(15,111,255,.1);}

/* ── TOAST NOTIFICATIONS ── */
#toast{position:fixed;bottom:120px;left:50%;transform:translateX(-50%) translateY(60px);background:var(--surf2);border:1px solid var(--bdr);border-radius:30px;padding:16px 32px;font-family:var(--mono);font-size:16px;color:var(--bright);opacity:0;transition:all .3s;z-index:9999; box-shadow: 0 10px 30px rgba(0,0,0,0.8);}
#toast.show{transform:translateX(-50%) translateY(0);opacity:1;}
#toast.ok{border-color:var(--ok);}
#toast.err{border-color:var(--danger);}
#toast.warn{border-color:var(--warn);}

/* Modals */
.m-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:999;align-items:center;justify-content:center;}
.m-ov.open{display:flex;}
.modal{background:var(--surf);border:1px solid var(--bdr);border-radius:20px;padding:30px;width:min(90vw,450px);}
.modal h3{font-family:var(--sans);font-size:24px;color:var(--bright);margin-bottom:14px;}
.m-act{display:flex;gap:14px;justify-content:flex-end;margin-top:24px;}
.bsm{padding:12px 24px;border-radius:10px;font-family:var(--sans);font-weight:700;font-size:16px;}
.b-ghost{background:transparent;border:1px solid var(--bdr);color:var(--bright);}
.b-save{background:var(--ac);border:none;color:#fff;}
</style>
</head>
<body>

<div id="pin-screen">
  <div class="pin-vault-name" id="pin-vault-name">Cookie Vault</div>
  <div class="pin-dots" id="pin-dots">
    <div class="pin-dot"></div><div class="pin-dot"></div><div class="pin-dot"></div>
    <div class="pin-dot"></div><div class="pin-dot"></div><div class="pin-dot"></div>
  </div>
  <div class="pin-pad" id="pin-pad">
    <div class="pin-key" data-v="1">1</div><div class="pin-key" data-v="2">2</div><div class="pin-key" data-v="3">3</div>
    <div class="pin-key" data-v="4">4</div><div class="pin-key" data-v="5">5</div><div class="pin-key" data-v="6">6</div>
    <div class="pin-key" data-v="7">7</div><div class="pin-key" data-v="8">8</div><div class="pin-key" data-v="9">9</div>
    <div class="pin-key clear" data-v="clear" style="font-size:16px;line-height:36px;color:var(--dim);">CLR</div>
    <div class="pin-key" data-v="0">0</div>
    <div class="pin-key del" data-v="del" style="font-size:20px;line-height:36px;color:var(--danger);">⌫</div>
  </div>
  <div id="pin-err" style="color:var(--danger); font-family:var(--mono); margin-top:15px; font-size:14px; min-height:20px;"></div>
  <div id="pin-lock-msg" style="color:var(--warn); font-family:var(--mono); margin-top:5px; font-size:14px;"></div>
  <div id="pin-decoy-hint" style="font-family:var(--mono); font-size:10px; color:rgba(74,106,138,.4); margin-top:20px;">configure decoy →</div>
</div>

<div id="drawer-overlay"></div>
<button id="menu-pill">☰ Menu</button>

<div id="app">
  <header class="hdr">
    <div class="hdr-icon">🔐</div>
    <div class="hdr-title" id="vault-title">Cookie <span>Vault</span></div>
    <div class="hdr-search">
      <span class="srch-ico">🔍</span>
      <input type="text" id="search-in" placeholder="Search cookies or groups...">
    </div>
    <div class="hdr-right">
      <button class="hdr-meta-btn" id="hdr-stats-btn">📊 Stats</button>
      <button class="hdr-meta-btn" id="hdr-cl-btn">📝 Log</button>
      <button class="hdr-meta-btn" id="hdr-sync-btn">🔄 Sync</button>
      <button class="btn-add" id="hdr-add">+ Add</button>
      <div id="sync-dot" data-state="off" style="width:12px;height:12px;border-radius:50%;background:var(--dim);margin-left:8px;"></div>
    </div>
  </header>

  <div class="app-body">
    <aside class="sidebar" id="sidebar">
      <div class="sb-hd">
        <div class="sb-lbl">Filter Data</div>
      </div>
      <div class="sb-nav" id="sb-nav">
        <div class="sb-all on" data-t="all" data-filter="all">All Groups</div>
        <div class="sb-item" data-filter="pinned">📌 Pinned</div>
        <div class="sb-item" data-filter="banned">🚫 Banned</div>
        <div class="sb-item" data-filter="alts">⟁ Has Alts</div>
        <div class="sb-div"></div>
        </div>
      
      <div class="sb-dock">
        <div class="sb-dock-label">⌘ Commands</div>
        <div class="sb-dock-grid">
           <div class="dock-cmd" id="sb-exp"><div class="dock-cmd-txt">Export</div></div>
           <div class="dock-cmd" id="sb-vault-settings"><div class="dock-cmd-txt">Settings</div></div>
           <div class="dock-cmd" id="sb-trash" style="border-color:var(--warn);"><div class="dock-cmd-txt" style="color:var(--warn)">Recycle Bin (<span id="trash-cnt">0</span>)</div></div>
           <div class="dock-cmd danger" id="sb-clr"><div class="dock-cmd-txt">Forget All</div></div>
        </div>
      </div>
    </aside>

    <main class="main" id="main">
      
      <nav class="swipe-tabs" id="swipe-tabs">
        <div class="swipe-tab active" data-t="all">All Data</div>
        </nav>

      <div class="paste-panel" id="paste-panel">
        <div class="paste-hd" id="paste-toggle">
          <div class="paste-hd-title">Paste Cookies</div>
        </div>
        <div class="paste-body">
          <textarea class="paste-ta" id="paste-ta" placeholder="username:password:cookie&#10;username:cookie&#10;cookie only"></textarea>
          <div class="paste-ft">
             <div id="paste-info" style="font-family:var(--mono); color:var(--dim); font-size:12px;">Awaiting input...</div>
             <button class="btn-primary" id="add-btn" disabled>+ Add to Vault</button>
          </div>
        </div>
      </div>

      <div class="paste-panel" id="ban-terminal" style="border-color:rgba(255,48,96,.3);">
        <div class="paste-hd" id="bt-toggle" style="background:rgba(255,48,96,.05); border-color:rgba(255,48,96,.2);">
          <div class="paste-hd-title" style="color:var(--danger)">Ban Checker Terminal</div>
          <div id="bt-worker-status" style="font-family:var(--mono);font-size:11px;color:var(--dim);">No workers configured</div>
        </div>
        <div class="paste-body" id="bt-body">
          <div style="padding:16px; border-bottom:1px solid var(--bdr); display:flex; gap:12px;">
             <button class="btn-primary" id="bt-run" style="background:var(--danger);">▶ Run Check</button>
             <button class="btn-primary" id="bt-stop" style="background:var(--surf2); border:1px solid var(--bdr);" disabled>■ Stop</button>
             <label style="font-family:var(--mono); color:var(--dim); display:flex; align-items:center; gap:8px;">
               <input type="checkbox" id="bt-skip-banned" checked style="width:18px;height:18px;"> Skip Banned
             </label>
             <div id="bt-progress" style="margin-left:auto; font-family:var(--mono); color:var(--dim);"></div>
          </div>
          <div id="bt-log" style="height:200px; overflow-y:auto; padding:16px; font-family:var(--mono); font-size:12px; line-height:1.8; color:var(--txt);"></div>
          <div class="paste-ft">
            <div id="bt-summary" style="font-family:var(--mono); font-size:11px; color:var(--dim);">Ready</div>
            <button class="btn-primary" id="bt-export-failed" style="display:none; padding:8px 16px; font-size:12px; background:var(--warn); color:#000;">Export Failed (u:p:c)</button>
            <button class="btn-primary" id="bt-clear-log" style="padding:8px 16px; font-size:12px; background:var(--surf2); border:1px solid var(--bdr);">Clear Log</button>
          </div>
        </div>
      </div>

      <div id="vault"></div>
      
    </main>
