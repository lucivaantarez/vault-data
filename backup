document.getElementById('p-padd-ok').addEventListener('click', () => {
  const g = vault.find(x => x.id === panelId); if(!g) return;
  const txt = document.getElementById('p-padd-ta').value;
  const parsed = [];
  const lines = txt.split('\n');
  for(let i=0; i<lines.length; i++){
    let line = lines[i].trim(); if(!line) continue;
    let idx = line.indexOf(COOKIE_PFX); if(idx===-1) continue;
    let cookie = line.substring(idx), pre = line.substring(0,idx).replace(/:$/,'');
    if(!pre) parsed.push({username:null,password:null,cookie});
    else {
      let ci = pre.indexOf(':');
      if(ci===-1) parsed.push({username:pre,password:null,cookie});
      else parsed.push({username:pre.substring(0,ci),password:pre.substring(ci+1),cookie});
    }
  }
  if(!parsed.length){ toast('No valid cookies', 'err'); return; }
  const existing = new Set(g.cookies.map(c=>c.cookie));
  const fresh = parsed.filter(c=>!existing.has(c.cookie));
  if(!fresh.length) { toast('All duplicates', 'warn'); return; }
  g.cookies.push(...fresh); saveVault(); refreshPanel(); render();
  document.getElementById('p-padd-form').style.display='none'; document.getElementById('p-padd-ta').value='';
  toast(`Added ${fresh.length} cookies`, 'ok');
});

