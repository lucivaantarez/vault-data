// BAN CHECKER LOGIC
// ═══════════════════════════════════════
function getWorkerUrls() { try{ return JSON.parse(localStorage.getItem('cv_worker_urls')||'[]'); }catch{ return []; } }
function btLog(msg, type='info') {
  const log = document.getElementById('bt-log');
  const div = document.createElement('div');
  div.style.cssText = `margin-bottom:6px; ${type==='err'?'color:var(--danger)':type==='ok'?'color:var(--ok)':type==='warn'?'color:var(--warn)':'color:var(--txt)'}`;
  div.textContent = msg;
  log.appendChild(div);
  log.scrollTop = log.scrollHeight;
}

document.getElementById('bt-toggle').addEventListener('click', () => {
  const body = document.getElementById('bt-body');
  body.style.display = body.style.display === 'block' ? 'none' : 'block';
  const urls = getWorkerUrls();
  document.getElementById('bt-worker-status').textContent = urls.length ? `${urls.length} workers ready` : 'No workers configured';
});

document.getElementById('bt-run').addEventListener('click', async () => {
  const urls = getWorkerUrls();
  if(!urls.length) { toast('Configure CF Workers in Settings first', 'err'); return; }
  
  banCheckAbort = false;
  banFailedCookies = [];
  document.getElementById('bt-run').disabled = true;
  document.getElementById('bt-stop').disabled = false;
  document.getElementById('bt-log').innerHTML = '';
  document.getElementById('bt-export-failed').style.display = 'none';
  
  const skipBanned = document.getElementById('bt-skip-banned').checked;
  let active=0, banned=0, expired=0, errors=0, done=0;
  
  let toCheck = [];
  vault.forEach(g => {
    if(skipBanned && g.banned) return;
    g.cookies.forEach(c => toCheck.push({g, c}));
  });
  
  btLog(`Starting check for ${toCheck.length} cookies...`, 'info');
  
  for(let i=0; i<toCheck.length; i++) {
    if(banCheckAbort) break;
    const item = toCheck[i];
    const url = urls[banWorkerIdx % urls.length]; banWorkerIdx++;
    document.getElementById('bt-progress').textContent = `${i+1}/${toCheck.length}`;
    
    try {
      const r = await fetch(url, { method: 'POST', body: JSON.stringify({cookie: item.c.cookie}), headers: {'Content-Type': 'application/json'} });
      if(!r.ok) throw new Error('HTTP ' + r.status);
      const res = await r.json();
      
      if(res.status === 'active') { active++; item.c.banStatus = 'active'; btLog(`[OK] ${item.c.username||'Anonymous'} is active`, 'ok'); }
      else if(res.status === 'banned') { banned++; item.c.banStatus = 'banned'; banFailedCookies.push(item.c); btLog(`[BAN] ${item.c.username||'Anonymous'} is BANNED`, 'err'); }
      else if(res.status === 'expired') { expired++; item.c.banStatus = 'expired'; banFailedCookies.push(item.c); btLog(`[EXP] ${item.c.username||'Anonymous'} expired`, 'warn'); }
      else { errors++; btLog(`[?] Unknown status for ${item.c.username}`, 'warn'); }
    } catch (e) {
      errors++; banWorkerIdx++; btLog(`[ERR] Worker failed: ${e.message}`, 'err');
    }
    await new Promise(res => setTimeout(res, 150)); // rate limit buffer
  }
  
  saveVault(); render();
  document.getElementById('bt-summary').textContent = `Done - Active:${active} Banned:${banned} Expired:${expired} Err:${errors}`;
  if(banFailedCookies.length) document.getElementById('bt-export-failed').style.display = 'block';
  document.getElementById('bt-run').disabled = false;
  document.getElementById('bt-stop').disabled = true;
  if(banCheckAbort) btLog('Check aborted by user.', 'warn');
});

document.getElementById('bt-stop').addEventListener('click', () => { banCheckAbort = true; haptic(); });
document.getElementById('bt-clear-log').addEventListener('click', () => { document.getElementById('bt-log').innerHTML = ''; });
document.getElementById('bt-export-failed').addEventListener('click', () => {
  const txt = banFailedCookies.map(c => `${c.username||''}:${c.password||''}:${c.cookie}`).join('\n');
  const a = document.createElement('a');
  a.href = 'data:text/plain;charset=utf-8,' + encodeURIComponent(txt);
  a.download = `banned-cookies-${Date.now()}.txt`;
  a.click();
  toast('Exported flagged cookies', 'ok');
});

